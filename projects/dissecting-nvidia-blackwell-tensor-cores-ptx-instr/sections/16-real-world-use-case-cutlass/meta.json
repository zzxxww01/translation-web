      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "接下来我们探讨一个实际用例：分块 GEMM 内循环模式，即沿着内部维度 K 连续加载分块，从而计算出输出矩阵的单个分块。",
          "model": "pro",
          "created_at": "2026-04-01T23:38:38.133334",
          "tokenized_text": null,
          "format_issues": []
        }
      },
      "confirmed": null,
