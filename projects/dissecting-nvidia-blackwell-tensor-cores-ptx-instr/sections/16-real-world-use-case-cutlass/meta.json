{
  "section_id": "16-real-world-use-case-cutlass",
  "title": "Real-world Use Case: CUTLASS",
  "title_translation": "实际应用案例：CUTLASS",
  "paragraphs": [
    {
      "id": "p000",
      "index": 0,
      "source": "Here we look at a real world use case: the tiled GEMM inner-loop pattern of continuously loading tiles along the inner dimension K to compute a single tile of an output matrix.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0147",
      "parent_block_index": 147,
      "parent_block_type": "p",
      "parent_block_markdown": "Here we look at a real world use case: the tiled GEMM inner-loop pattern of continuously loading tiles along the inner dimension K to compute a single tile of an output matrix.",
      "parent_block_plain_text": "Here we look at a real world use case: the tiled GEMM inner-loop pattern of continuously loading tiles along the inner dimension K to compute a single tile of an output matrix.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 176,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
