{
  "section_id": "15-throughput-at-different-in-fli",
  "title": "Throughput at Different In-Flight Instruction Count",
  "title_translation": "不同在途指令数下的吞吐量",
  "paragraphs": [
    {
      "id": "p000",
      "index": 0,
      "source": "In our throughput benchmark, we set high numbers of in-flight instructions to amortize instruction issuing and commit wait overheads, ranging from 256 to 1024. However, kernels typically use 1 to 4 in-flight MMA instructions. We benchmarked the throughput at 1 to 10 in-flight instructions, and we discuss the changes in throughput here.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0140",
      "parent_block_index": 140,
      "parent_block_type": "p",
      "parent_block_markdown": "In our throughput benchmark, we set high numbers of in-flight instructions to amortize instruction issuing and commit wait overheads, ranging from 256 to 1024. However, kernels typically use 1 to 4 in-flight MMA instructions. We benchmarked the throughput at 1 to 10 in-flight instructions, and we discuss the changes in throughput here.",
      "parent_block_plain_text": "In our throughput benchmark, we set high numbers of in-flight instructions to amortize instruction issuing and commit wait overheads, ranging from 256 to 1024. However, kernels typically use 1 to 4 in-flight MMA instructions. We benchmarked the throughput at 1 to 10 in-flight instructions, and we discuss the changes in throughput here.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 337,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
      "format_errors": [],
      "is_heading": false,
      "heading_level": null,
      "heading_chain": [],
      "is_metadata": false,
      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "在我们的吞吐量基准测试中，我们设置了大量的飞行中指令，数量在 256 到 1024 之间，以此来摊销指令发射与提交等待的开销。然而，实际内核通常仅使用 1 到 4 条飞行中 MMA 指令。因此，我们对 1 到 10 条飞行中指令的吞吐量进行了基准测试，并在此探讨其吞吐量的变化规律。",
          "model": "pro",
          "created_at": "2026-04-01T23:36:17.816840",
          "tokenized_text": null,
          "format_issues": []
        }
      },
      "confirmed": null,
      "confirmed_tokenized": null,
      "confirmed_format_issues": [],
