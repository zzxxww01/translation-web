    {
      "id": "p002",
      "index": 2,
      "source": "Intel presented their UCIe-S compatible die-to-die (D2D) interface. It can reach up to 48 Gb/s/lane over 16 lanes with UCIe-S and up to 56 Gb/s/lane with a custom protocol. It works on a standard organic package for a distance of up to 30mm. Interestingly, it was manufactured on Intel’s 22nm process.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0254",
      "parent_block_index": 254,
      "parent_block_type": "p",
      "parent_block_markdown": "Intel presented their UCIe-S compatible die-to-die (D2D) interface. It can reach up to 48 Gb/s/lane over 16 lanes with UCIe-S and up to 56 Gb/s/lane with a custom protocol. It works on a standard organic package for a distance of up to 30mm. Interestingly, it was manufactured on Intel’s 22nm process.",
      "parent_block_plain_text": "Intel presented their UCIe-S compatible die-to-die (D2D) interface. It can reach up to 48 Gb/s/lane over 16 lanes with UCIe-S and up to 56 Gb/s/lane with a custom protocol. It works on a standard organic package for a distance of up to 30mm. Interestingly, it was manufactured on Intel’s 22nm process.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 301,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
      "format_errors": [],
      "is_heading": false,
      "heading_level": null,
      "heading_chain": [],
      "is_metadata": false,
      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "英特尔展示了其符合 UCIe-S（通用芯粒互连-标准版）标准的裸片到裸片（D2D）接口。该接口在 UCIe-S 协议下，通过 16 个通道可实现高达 48 Gb/s/通道的速率；若采用定制协议，速率更可提升至 56 Gb/s/通道。它能在标准有机封装上工作，传输距离最远可达 30 毫米。值得注意的是，该接口采用了英特尔的 22 纳米制程节点制造。",
          "model": "pro",
          "created_at": "2026-04-18T22:51:31.645109",
          "tokenized_text": null,
          "format_issues": []
        }
