    {
      "id": "p011",
      "index": 11,
      "source": "Nvidia had a preference for GC due to its several advantages – it enables 2D density, offers a smaller footprint, is easier to manufacture, and allows for simpler wafer-level testing compared to EC. However, the company is also aware of GC’s several drawbacks – it generally introduces higher optical loss and has a narrower optical bandwidth than EC (the latter can generally accommodate a broader spectral range).",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0257",
      "parent_block_index": 257,
      "parent_block_type": "p",
      "parent_block_markdown": "Nvidia had a preference for GC due to its several advantages – it enables 2D density, offers a smaller footprint, is easier to manufacture, and allows for simpler wafer-level testing compared to EC. However, the company is also aware of GC’s several drawbacks – it generally introduces higher optical loss and has a narrower optical bandwidth than EC (the latter can generally accommodate a broader spectral range).",
      "parent_block_plain_text": "Nvidia had a preference for GC due to its several advantages – it enables 2D density, offers a smaller footprint, is easier to manufacture, and allows for simpler wafer-level testing compared to EC. However, the company is also aware of GC’s several drawbacks – it generally introduces higher optical loss and has a narrower optical bandwidth than EC (the latter can generally accommodate a broader spectral range).",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 415,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
      "format_errors": [],
      "is_heading": false,
      "heading_level": null,
      "heading_chain": [],
      "is_metadata": false,
      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "英伟达更倾向于采用光栅耦合（GC），因为它具备多项优势——能够实现二维高密度、占用空间更小、制造更简单，并且与边缘耦合（EC）相比，可支持更简便的晶圆级测试。不过，该公司也清楚光栅耦合存在若干缺点——其光学损耗通常更高，光学带宽也比边缘耦合窄（后者通常能容纳更宽的光谱范围）。",
          "model": "pro",
          "created_at": "2026-04-22T18:22:11.403368",
          "tokenized_text": null,
          "format_issues": []
        }
