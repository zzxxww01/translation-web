      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "与其他专注于两端对接解决方案的CPO供应商不同，Ranovus专注于开发可互操作系统，并将以太网标准互操作性作为核心差异化点。他们在OCP 2024上与联发科合作，展示了8x100G DR8光互操作性，证明可与多家第三方供应商的标准8x100G可插拔模块实现互操作。",
          "model": "pro",
          "created_at": "2026-04-22T18:43:21.189527",
          "tokenized_text": null,
          "format_issues": []
        }
