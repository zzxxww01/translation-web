      "translations": {
        "pro": {
          "text": "Ranovus的上市策略以提供客户所需的互操作解决方案为核心。目前这意味着100G PAM4 DR光器件，但微环谐振器调制技术的采用为其转向其他方案打开了通道，例如采用56 Gbaud NRZ，并通过波分复用（WDM）结合4个波长，在每对光纤上实现400G传输。",
          "model": "pro",
          "created_at": "2026-04-22T18:43:21.189583",
