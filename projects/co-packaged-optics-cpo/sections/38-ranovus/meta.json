    {
      "id": "p002",
      "index": 2,
      "source": "Ranovus’s Odin Optical Engine uses Microring Resonator modulators and can deliver up to 64 lanes of 100Gbit/s using PAM4 modulation.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0551",
      "parent_block_index": 551,
      "parent_block_type": "p",
      "parent_block_markdown": "Ranovus’s Odin Optical Engine uses Microring Resonator modulators and can deliver up to 64 lanes of 100Gbit/s using PAM4 modulation.",
      "parent_block_plain_text": "Ranovus’s Odin Optical Engine uses Microring Resonator modulators and can deliver up to 64 lanes of 100Gbit/s using PAM4 modulation.",
      "parent_source_html": null,
      "parent_inline_elements": [],
