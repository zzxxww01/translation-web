{
  "section_id": "15-packaging-economics",
  "title": "Packaging Economics",
  "title_translation": "封装经济学",
  "paragraphs": [
    {
      "id": "p000",
      "index": 0,
      "source": "Apple pioneered TSMC’s advanced packaging business. InFO launched with the A10 in 2016, and Apple scaled it from $1.8B in 2018 to $3.8B in 2025. CoWoS was a rounding error at $118M in 2018. By 2025, it reached $9.6B. The crossover happened in 2022 when AI demand exploded. Apple created TSMC’s advanced packaging business with InFO. Nvidia’s CoWoS demand now drives it.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0327",
      "parent_block_index": 327,
      "parent_block_type": "p",
      "parent_block_markdown": "Apple pioneered TSMC’s advanced packaging business. InFO launched with the A10 in 2016, and Apple scaled it from $1.8B in 2018 to $3.8B in 2025. CoWoS was a rounding error at $118M in 2018. By 2025, it reached $9.6B. The crossover happened in 2022 when AI demand exploded. Apple created TSMC’s advanced packaging business with InFO. Nvidia’s CoWoS demand now drives it.",
      "parent_block_plain_text": "Apple pioneered TSMC’s advanced packaging business. InFO launched with the A10 in 2016, and Apple scaled it from $1.8B in 2018 to $3.8B in 2025. CoWoS was a rounding error at $118M in 2018. By 2025, it reached $9.6B. The crossover happened in 2022 when AI demand exploded. Apple created TSMC’s advanced packaging business with InFO. Nvidia’s CoWoS demand now drives it.",
      "parent_source_html": null,
