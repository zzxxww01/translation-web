    {
      "id": "p004",
      "index": 4,
      "source": "ASML: Apple has never purchased directly from ASML, yet Apple may be the primary reason ASML exists in its current form. Apple’s leading-edge chip requirements drive TSMC’s demand for EUV lithography. TSMC is ASML’s largest customer. ASML’s market cap grew from approximately €15B in 2010 to €380B+ in 2024, a 25x increase during the Apple-TSMC era.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0366",
      "parent_block_index": 366,
      "parent_block_type": "p",
      "parent_block_markdown": "ASML: Apple has never purchased directly from ASML, yet Apple may be the primary reason ASML exists in its current form. Apple’s leading-edge chip requirements drive TSMC’s demand for EUV lithography. TSMC is ASML’s largest customer. ASML’s market cap grew from approximately €15B in 2010 to €380B+ in 2024, a 25x increase during the Apple-TSMC era.",
      "parent_block_plain_text": "ASML: Apple has never purchased directly from ASML, yet Apple may be the primary reason ASML exists in its current form. Apple’s leading-edge chip requirements drive TSMC’s demand for EUV lithography. TSMC is ASML’s largest customer. ASML’s market cap grew from approximately €15B in 2010 to €380B+ in 2024, a 25x increase during the Apple-TSMC era.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 349,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
