    {
      "id": "p004",
      "index": 4,
      "source": "M-series shows exponential growth in its early years, with 2020–2023 CAGR exceeding 170%. But the curve is concave. Growth decelerates sharply after 2023, dropping to roughly 8% CAGR through 2030.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0245",
      "parent_block_index": 245,
      "parent_block_type": "p",
      "parent_block_markdown": "M-series shows exponential growth in its early years, with 2020–2023 CAGR exceeding 170%. But the curve is concave. Growth decelerates sharply after 2023, dropping to roughly 8% CAGR through 2030.",
      "parent_block_plain_text": "M-series shows exponential growth in its early years, with 2020–2023 CAGR exceeding 170%. But the curve is concave. Growth decelerates sharply after 2023, dropping to roughly 8% CAGR through 2030.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 196,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
