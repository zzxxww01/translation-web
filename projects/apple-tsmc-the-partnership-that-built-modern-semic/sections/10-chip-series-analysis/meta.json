      "translations": {
        "pro": {
          "text": "A系列的需求呈线性。2014 年至 2030 年的复合年增长率（CAGR）不足 2%，且在部分时间段内绝对规模停滞或下滑。2017 年至 2019 年间，增长率为零。2022 年至 2024 年间，需求略有收缩。",
          "model": "pro",
          "created_at": "2026-04-10T16:22:51.472146",
          "tokenized_text": null,
          "format_issues": []
        }
      },
      "confirmed": null,
