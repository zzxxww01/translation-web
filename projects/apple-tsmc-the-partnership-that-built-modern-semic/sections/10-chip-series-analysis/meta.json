    {
      "id": "p001",
      "index": 1,
      "source": "A-series demand is linear. The 2014–2030 CAGR is under 2%, and there are stretches where absolute volumes are flat or declining. From 2017 to 2019, growth was zero. From 2022 to 2024, demand slightly contracted.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0242",
      "parent_block_index": 242,
      "parent_block_type": "p",
      "parent_block_markdown": "A-series demand is linear. The 2014–2030 CAGR is under 2%, and there are stretches where absolute volumes are flat or declining. From 2017 to 2019, growth was zero. From 2022 to 2024, demand slightly contracted.",
      "parent_block_plain_text": "A-series demand is linear. The 2014–2030 CAGR is under 2%, and there are stretches where absolute volumes are flat or declining. From 2017 to 2019, growth was zero. From 2022 to 2024, demand slightly contracted.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 211,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
