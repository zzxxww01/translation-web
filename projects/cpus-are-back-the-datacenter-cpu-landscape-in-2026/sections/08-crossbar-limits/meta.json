      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "随着设计人员试图进一步增加核心数量，他们触及了这些早期互连架构的扩展瓶颈。由于追求极低延迟与一致性，交叉开关（Crossbar）设计采用了全互连模式，即裸片上的每个核心都有一条独立链路与其他所有核心相连。然而，随着核心数量增多，链路数量激增，导致复杂性大幅上升。",
          "model": "pro",
          "created_at": "2026-04-08T15:55:38.842745",
          "tokenized_text": null,
          "format_issues": []
        }
      },
