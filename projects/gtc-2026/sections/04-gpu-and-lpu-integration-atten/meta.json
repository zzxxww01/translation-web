    {
      "id": "p002",
      "index": 2,
      "source": "Now with an understanding of what LPUs are good for we can understand how they fit into inference setups. NVIDIA introduced LPUs to improve the performance of high interactivity scenarios. In those scenarios, LPUs can leverage their low-latency capabilities to improve the decode phase latencies. One way LPUs can improve decode phase latencies is by applying the Attention FFN Disaggregation (AFD) technique, introduced in MegaScale-Infer and Step-3.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [
        {
          "type": "link",
          "text": "MegaScale-Infer",
          "start": 424,
          "end": 439,
          "href": "https://arxiv.org/abs/2504.02263",
          "title": null,
          "span_id": "LINK_1"
        },
        {
          "type": "link",
          "text": "Step-3",
          "start": 444,
          "end": 450,
          "href": "https://arxiv.org/abs/2507.19427",
          "title": null,
          "span_id": "LINK_2"
        }
      ],
      "parent_block_id": "b0037",
      "parent_block_index": 37,
      "parent_block_type": "p",
