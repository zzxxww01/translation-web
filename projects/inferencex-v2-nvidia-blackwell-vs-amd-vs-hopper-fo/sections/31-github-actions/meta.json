{
  "section_id": "31-github-actions",
  "title": "GitHub Actions",
  "title_translation": "GitHub Actions",
  "paragraphs": [
    {
      "id": "p000",
      "index": 0,
      "source": "In the spirit of open source, all runs occur on GitHub Actions, so benchmark results are verifiable, transparent, and reproducible. However, GitHub outages have been a constant obstacle to our goals recently. We have seen more unicorns lately than any other animal! But maybe it’s time for us to touch some grass.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [
        {
          "type": "link",
          "text": "We have seen more unicorns lately than any other animal",
          "start": 209,
          "end": 264,
          "href": "https://github.com/503.html",
          "title": null,
          "span_id": "LINK_1"
        }
      ],
      "parent_block_id": "b0358",
      "parent_block_index": 358,
      "parent_block_type": "p",
      "parent_block_markdown": "In the spirit of open source, all runs occur on GitHub Actions, so benchmark results are verifiable, transparent, and reproducible. However, GitHub outages have been a constant obstacle to our goals recently. [We have seen more unicorns lately than any other animal](https://github.com/503.html)! But maybe it’s time for us to touch some grass.",
      "parent_block_plain_text": "In the spirit of open source, all runs occur on GitHub Actions, so benchmark results are verifiable, transparent, and reproducible. However, GitHub outages have been a constant obstacle to our goals recently. We have seen more unicorns lately than any other animal! But maybe it’s time for us to touch some grass.",
      "parent_source_html": null,
      "parent_inline_elements": [
        {
          "type": "link",
          "text": "We have seen more unicorns lately than any other animal",
          "start": 209,
          "end": 264,
          "href": "https://github.com/503.html",
