{
  "section_id": "27-gpt-oss-120b-single-node",
  "title": "GPT-OSS 120B Single Node",
  "title_translation": "GPT-OSS 120B 单节点",
  "paragraphs": [
    {
      "id": "p000",
      "index": 0,
      "source": "MI300X, MI325X, H200, and H100 group in the lower-left of the throughput vs interactivity plot, indicating broadly similar tradeoffs, with Nvidia generally holding a modest lead. The next step up is MI355X, which delivers roughly more than 2x higher token throughput per GPU at a given interactivity level, relative to that first group. Within MI355X, ATOM shifts the curve toward higher throughput at low interactivity, suggesting it prioritizes peak throughput over per-user responsiveness.",
      "source_html": null,
      "element_type": "p",
      "inline_elements": [],
      "parent_block_id": "b0336",
      "parent_block_index": 336,
      "parent_block_type": "p",
      "parent_block_markdown": "MI300X, MI325X, H200, and H100 group in the lower-left of the throughput vs interactivity plot, indicating broadly similar tradeoffs, with Nvidia generally holding a modest lead. The next step up is MI355X, which delivers roughly more than 2x higher token throughput per GPU at a given interactivity level, relative to that first group. Within MI355X, ATOM shifts the curve toward higher throughput at low interactivity, suggesting it prioritizes peak throughput over per-user responsiveness.",
      "parent_block_plain_text": "MI300X, MI325X, H200, and H100 group in the lower-left of the throughput vs interactivity plot, indicating broadly similar tradeoffs, with Nvidia generally holding a modest lead. The next step up is MI355X, which delivers roughly more than 2x higher token throughput per GPU at a given interactivity level, relative to that first group. Within MI355X, ATOM shifts the curve toward higher throughput at low interactivity, suggesting it prioritizes peak throughput over per-user responsiveness.",
      "parent_source_html": null,
      "parent_inline_elements": [],
      "segment_start": 0,
      "segment_end": 492,
      "expected_tokens": [],
      "format_recovery_status": "not_applicable",
      "format_errors": [],
      "is_heading": false,
      "heading_level": null,
      "heading_chain": [],
      "is_metadata": false,
      "metadata_type": null,
      "translations": {
        "pro": {
          "text": "MI300X、MI325X、H200 和 H100 扎堆在吞吐量-交互性曲线图的左下方，表明它们的性能取舍大同小异，英伟达总体上占据微弱优势。再上一个台阶是 MI355X，在同等交互性下，其单 GPU 的 token 吞吐量比第一梯队高出两倍有余。在 MI355X 阵营中，ATOM 将曲线向低交互性、高吞吐量的方向拉扯，这表明它重保峰值吞吐量，而非单用户响应速度。",
          "model": "pro",
          "created_at": "2026-04-08T01:10:47.246594",
          "tokenized_text": null,
          "format_issues": []
        }
      },
      "confirmed": null,
      "confirmed_tokenized": null,
      "confirmed_format_issues": [],
      "status": "translated",
      "ai_insight": {
        "overall_score": 9.315,
        "is_excellent": true,
        "applied_terms": [],
        "style": "专业技术",
        "steps": {
