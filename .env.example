# Translation Agent - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============ LLM 配置 ============
# Gemini 备用付费 API Key（必填）
GEMINI_BACKUP_API_KEY=your_paid_gemini_api_key_here

# Gemini 模型配置（可选）
# GEMINI_MODEL=gemini-3-pro-preview
# GEMINI_TEMPERATURE=0.7
# GEMINI_MAX_TOKENS=8192
#
# Request timeouts (seconds)
# GEMINI_TIMEOUT=120
# POST_TRANSLATE_TIMEOUT=60
# POST_OPTIMIZE_TIMEOUT=180
# POST_TITLE_TIMEOUT=45

# OpenAI（预留，暂未使用）
# OPENAI_API_KEY=your_openai_api_key_here

# ============ 服务器配置 ============
# API_HOST=127.0.0.1
# API_PORT=8000
# DEBUG=false

# ============ 存储路径 ============
# PROJECTS_PATH=projects
# CONVERSATIONS_PATH=conversations
# GLOSSARY_PATH=glossary

# ============ 缓存配置 ============
# CACHE_ENABLED=false
# CACHE_BACKEND=memory
# CACHE_TTL=86400
# REDIS_URL=redis://localhost:6379/0

# ============ 限流配置 ============
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_PER_HOUR=1000

# ============ 日志配置 ============
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# LOG_FILE=logs/app.log

# ============ 数据库（预留） ============
# DATABASE_URL=postgresql://user:password@localhost/translation_agent

# ============ 认证（预留） ============
# JWT_SECRET_KEY=your_secret_key_here

# ============ 监控 ============
# SENTRY_DSN=https://your-sentry-dsn
# ENABLE_METRICS=false
