# Translation Agent - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============ LLM 配置 ============
# Gemini API Key（必填）
# LLM_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BACKUP_API_KEY=your_gemini_backup_api_key_here

# Gemini 代理配置（按需填写）
# GEMINI_HTTP_PROXY=http://127.0.0.1:7890
# GEMINI_HTTPS_PROXY=http://127.0.0.1:7890
# GEMINI_NO_PROXY=localhost,127.0.0.1

# VectorEngine 配置
VECTORENGINE_API_KEY=your_vectorengine_api_key_here
VECTORENGINE_BACKUP_API_KEY=your_vectorengine_backup_api_key_here
# VECTORENGINE_BASE_URL=https://your-api-endpoint.com/v1

# Gemini 模型配置（可选）
# 1) 配置别名对应的真实模型名
# GEMINI_FLASH_MODEL=gemini-flash-latest
# GEMINI_PRO_MODEL=gemini-3-pro-preview
# GEMINI_PREVIEW_MODEL=gemini-3.1-pro-preview
# 2) 选择默认主模型与备用模型（可填 alias 或真实模型名）
# GEMINI_MODEL=pro
# GEMINI_BACKUP_MODEL=flash
# GEMINI_TEMPERATURE=0.7
# GEMINI_MAX_TOKENS=8192
#
# Request timeouts (seconds)
# GEMINI_TIMEOUT=120
# POST_TRANSLATE_TIMEOUT=60
# POST_OPTIMIZE_TIMEOUT=180
# POST_TITLE_TIMEOUT=45

# ============ 服务器配置 ============
# API_HOST=127.0.0.1
# API_PORT=54321
# DEBUG=false

# CORS 配置（生产环境必须配置）
# CORS_ORIGINS=http://localhost:54321,http://127.0.0.1:54321

# 安全配置（公网环境必须）
# ALLOW_CUSTOM_PROMPTS=false  # 禁用自定义 prompt（防止注入）
# ENVIRONMENT=production       # 生产环境模式

# 访问控制（可选，推荐配置）
# IP_WHITELIST=203.0.113.1,203.0.113.2,203.0.113.3  # 团队成员 IP 白名单

# ============ 存储路径 ============
# PROJECTS_PATH=projects
# CONVERSATIONS_PATH=conversations
# GLOSSARY_PATH=glossary

# ============ 日志配置 ============
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# LOG_FILE=logs/app.log

# ============ 翻译配置 ============
# 翻译 prompt 风格：original（标准，保留完整推理）/ simplified（精简，紧凑中文）
# TRANSLATION_PROMPT_STYLE=original
