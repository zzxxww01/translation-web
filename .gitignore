# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# ----------------------------
# Environment / secrets
# ----------------------------
.env
.env.*
!.env.example

# LLM provider configuration (contains API keys)
config/llm_providers.yaml
config/*.local.yaml

# ----------------------------
# Runtime data (DO NOT publish)
# ----------------------------
# Exclude all project data (user translation work)
projects/*
!projects/.gitkeep
conversations/
data/
*.db
*.sqlite
*.sqlite3

# ----------------------------
# Frontend build artifacts
# ----------------------------
web/frontend/node_modules/
web/frontend/dist/
web/frontend/.next/
web/frontend/out/
web/frontend/lint-report.json

# ----------------------------
# Test / temporary artifacts
# ----------------------------
tests/*
!tests/conftest.py
!tests/unit/
tests/unit/*
!tests/unit/api/
!tests/unit/services/
tests/unit/api/*
tests/unit/services/*
!tests/unit/api/test_translation_stream_session.py
!tests/unit/services/test_translation_artifact_service.py
!tests/unit/services/test_translation_run_registry.py
!tests/unit/services/test_wechat_formatter.py
!tests/unit/services/test_inline_recovery_service.py
!tests/unit/services/test_project_export_service.py
!tests/unit/services/test_section_translation_executor.py
!tests/unit/llm/test_usage_metrics.py
.pytest_cache/
.tmp_testdata/
.coverage
htmlcov/
tests/.tmp/
tests/temp/
tests/**/__pycache__/

# ----------------------------
# IDE / local tooling
# ----------------------------
.vscode/
.idea/
.claude/
.antigravity/
*.sublime-project
*.sublime-workspace

# ----------------------------
# Logs / temp
# ----------------------------
*.log
logs/
*.tmp
*.swp
*.swo
*~

# ----------------------------
# OS files
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini
