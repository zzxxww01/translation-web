# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# ----------------------------
# Environment / secrets
# ----------------------------
.env
.env.*
!.env.example

# LLM provider configuration (contains API keys)
config/llm_providers.yaml
config/*.local.yaml

# ----------------------------
# Runtime data (DO NOT publish)
# ----------------------------
# Exclude all project data (user translation work)
projects/*
!projects/.gitkeep
conversations/
data/
*.db
*.sqlite
*.sqlite3

# ----------------------------
# Frontend build artifacts
# ----------------------------
web/frontend/node_modules/
web/frontend/dist/
web/frontend/.next/
web/frontend/out/
web/frontend/lint-report.json

# ----------------------------
# Test / temporary artifacts
# ----------------------------
.pytest_cache/
.tmp_testdata/
.coverage
htmlcov/
tests/.tmp/
tests/temp/
tests/**/__pycache__/

# ----------------------------
# IDE / local tooling
# ----------------------------
.vscode/
.idea/
.claude/
.antigravity/
*.sublime-project
*.sublime-workspace

# ----------------------------
# Logs / temp
# ----------------------------
*.log
logs/
*.tmp
*.swp
*.swo
*~

# ----------------------------
# OS files
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------
# Scratch / analysis artifacts (not part of the codebase)
# ----------------------------
tmp_findings_*.json
tmp_findings_*.py
translation-agent-analysis/
